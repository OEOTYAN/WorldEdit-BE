{
    // 用法说明 / Usage notes:
    // 0. 需要先安装 VS Code 扩展 `Tasks Shell Input`，本文件里的 `shellCommand.execute` 由它提供。
    //    Install the VS Code extension `Tasks Shell Input` first; `shellCommand.execute` in this file is provided by it.
    // 1. `MC_GDK_DEBUG_PATH`：GDK 版可执行文件完整路径 / full path to the GDK executable.
    // 2. `MC_BDS_DEBUG_PATH`：BDS 版可执行文件完整路径 / full path to the BDS executable.
    // 3. `MC_SYMBOLS_PATH`：可选，PDB/符号目录；可写单个目录，也可用 `;` 分隔多个目录。
    //    `MC_SYMBOLS_PATH`: optional PDB/symbol directory; can be a single directory or multiple directories separated by `;`.
    // 4. 设置好环境变量后，直接在 VS Code 里启动对应调试配置即可。
    //    After setting the environment variables, launch the corresponding debug configuration directly in VS Code.
    "version": "0.2.0",
    "configurations": [
        {
            // 自动启动 GDK 目标进程，并在进程稳定后附加调试器。
            // Automatically starts the GDK target process and attaches the debugger after the process becomes stable.
            "name": "GDK attach",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${input:launchAndGetPid_GDK}",
            "symbolSearchPath": "${input:getSymbolSearchPath}"
        },
        {
            // 自动启动 BDS 目标进程，并在进程稳定后附加调试器。
            // Automatically starts the BDS target process and attaches the debugger after the process becomes stable.
            "name": "BDS attach",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${input:launchAndGetPid_BDS}",
            "symbolSearchPath": "${input:getSymbolSearchPath}"
        }
    ],
    "inputs": [
        {
            "id": "getSymbolSearchPath",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                // 仅在设置了 `MC_SYMBOLS_PATH` 时返回符号搜索路径；未设置时留空。
                // Returns the symbol search path only when `MC_SYMBOLS_PATH` is set; otherwise returns an empty value.
                "command": "powershell",
                "commandArgs": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "if (-not [string]::IsNullOrWhiteSpace($env:MC_SYMBOLS_PATH)) { [Console]::Out.WriteLine($env:MC_SYMBOLS_PATH) }"
                ],
                "cwd": "${workspaceFolder}",
                "useFirstResult": true
            }
        },
        {
            "id": "launchAndGetPid_GDK",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "powershell",
                "commandArgs": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "$exePath = $env:MC_GDK_DEBUG_PATH; if ([string]::IsNullOrWhiteSpace($exePath)) { throw 'MC_DEBUG_PATH is not set.' }; if (-not (Test-Path $exePath)) { throw \"exe not found: $exePath\" }; $exePath = [System.IO.Path]::GetFullPath($exePath); $workingDir = Split-Path -Parent $exePath; $getMatchingProcesses = { Get-Process -ErrorAction SilentlyContinue | Where-Object { $_.Path -eq $exePath } }; $existing = @(& $getMatchingProcesses | Select-Object -ExpandProperty Id); Start-Process -FilePath $exePath -WorkingDirectory $workingDir | Out-Null; $stableTarget = $null; $candidateId = $null; $stableCount = 0; for ($i = 0; $i -lt 60 -and -not $stableTarget; $i++) { Start-Sleep -Milliseconds 500; $candidates = & $getMatchingProcesses | Where-Object { -not $existing -or $_.Id -notin $existing } | Sort-Object StartTime -Descending; $latest = $candidates | Select-Object -First 1; if (-not $latest) { $candidateId = $null; $stableCount = 0; continue }; if ($latest.Id -eq $candidateId) { $stableCount += 1 } else { $candidateId = $latest.Id; $stableCount = 1 }; if ($stableCount -ge 6) { $stableTarget = Get-Process -Id $candidateId -ErrorAction SilentlyContinue | Where-Object { $_.Path -eq $exePath } } }; if (-not $stableTarget) { throw 'Unable to locate a stable Minecraft.Windows process within 30 seconds.' }; [Console]::Out.WriteLine([string]$stableTarget.Id)"
                ],
                "cwd": "${workspaceFolder}",
                "useFirstResult": true
            }
        },
        {
            "id": "launchAndGetPid_BDS",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "powershell",
                "commandArgs": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "$exePath = $env:MC_BDS_DEBUG_PATH; if ([string]::IsNullOrWhiteSpace($exePath)) { throw 'MC_DEBUG_PATH is not set.' }; if (-not (Test-Path $exePath)) { throw \"exe not found: $exePath\" }; $exePath = [System.IO.Path]::GetFullPath($exePath); $workingDir = Split-Path -Parent $exePath; $getMatchingProcesses = { Get-Process -ErrorAction SilentlyContinue | Where-Object { $_.Path -eq $exePath } }; $existing = @(& $getMatchingProcesses | Select-Object -ExpandProperty Id); Start-Process -FilePath $exePath -WorkingDirectory $workingDir | Out-Null; $stableTarget = $null; $candidateId = $null; $stableCount = 0; for ($i = 0; $i -lt 60 -and -not $stableTarget; $i++) { Start-Sleep -Milliseconds 500; $candidates = & $getMatchingProcesses | Where-Object { -not $existing -or $_.Id -notin $existing } | Sort-Object StartTime -Descending; $latest = $candidates | Select-Object -First 1; if (-not $latest) { $candidateId = $null; $stableCount = 0; continue }; if ($latest.Id -eq $candidateId) { $stableCount += 1 } else { $candidateId = $latest.Id; $stableCount = 1 }; if ($stableCount -ge 6) { $stableTarget = Get-Process -Id $candidateId -ErrorAction SilentlyContinue | Where-Object { $_.Path -eq $exePath } } }; if (-not $stableTarget) { throw 'Unable to locate a stable Minecraft.Windows process within 30 seconds.' }; [Console]::Out.WriteLine([string]$stableTarget.Id)"
                ],
                "cwd": "${workspaceFolder}",
                "useFirstResult": true
            }
        }
    ]
}